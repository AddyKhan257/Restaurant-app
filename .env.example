# ============================================================
# Savoria Restaurant App — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# ── General ──────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://savoria:savoria@localhost:5432/savoria_db
DB_NAME=savoria_db
DB_USER=savoria
DB_PASSWORD=savoria
DB_HOST=localhost
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (SMTP) ─────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Savoria <noreply@savoria.com>

# ── Stripe Payments ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Django Superuser (for Docker seed) ───────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@savoria.com
DJANGO_SUPERUSER_PASSWORD=admin123

# ── Production Overrides ─────────────────────────────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
